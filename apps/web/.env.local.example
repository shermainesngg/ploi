# BRIDGE — environment variables
# Copy to .env.local and fill in. Restart the dev server after changes.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Settings → API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-side only — never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe ───────────────────────────────────────────────────────────────────
# Test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
# Created with `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
STRIPE_WEBHOOK_SECRET=whsec_your_secret

# ── Google Calendar sync ─────────────────────────────────────────────────────
# OAuth client (Web application) from https://console.cloud.google.com/apis/credentials
# Optional — without these, calendar sync is a silent no-op.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Encrypts the stored refresh token at rest (AES-256-GCM). Base64-encoded 32 bytes:
#   openssl rand -base64 32
GCAL_TOKEN_ENC_KEY=your-base64-32-byte-key

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
